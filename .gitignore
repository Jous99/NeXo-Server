# --- Node.js (Servidor Eden) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env

# --- Seguridad y Certificados (CRÍTICO) ---
# Ignoramos las llaves privadas y certificados generados para que cada 
# desarrollador tenga los suyos o se usen los de producción.
certs/*.key
certs/*.cert
# Si quieres compartir el .crt para que otros lo instalen, NO lo agregues aquí.

# --- C++ / CMake (Cliente) ---
build/
bin/
obj/
out/
CMakeFiles/
CMakeCache.txt
*.cmake
install/
# Archivos generados por compiladores específicos
*.o
*.a
*.pdb
*.ilk

# --- Visual Studio / Editores ---
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.db
*.opendb
*.cache
*.exp
*.lib
.vscode/
.idea/

# --- Base de Datos y Logs ---
# Ignorar el dump de la base de datos si haces backups locales
*.sql
# Si usas logs de MySQL en archivo
logs/*.log
*.log

# --- Archivos del Sistema ---
.DS_Store
Thumbs.db

# --- Ejecutables y binarios ---
*.exe
*.dll
*.so
*.app