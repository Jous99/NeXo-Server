# NeXo-Server — Variables de entorno
# Copia este archivo a .env y rellena los valores

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Base de datos MySQL ───────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nexo_user
DB_PASSWORD=cambia_esta_contraseña
DB_NAME=nexo_network
DB_POOL_SIZE=10

# ── JWT ───────────────────────────────────────────────────────
# Genera una clave larga y aleatoria: openssl rand -hex 32
JWT_SECRET=reemplaza_con_clave_larga_y_aleatoria_minimo_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Seguridad ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Forgejo (para actualizaciones desde el panel admin) ───────
# URL del repositorio en Forgejo (sin .git al final)
FORGEJO_REPO_URL=https://forgejo.joustech.space/NeXo/NeXoNetwork-Server
# Token de acceso personal de Forgejo (Settings → Applications → Access tokens)
FORGEJO_TOKEN=
