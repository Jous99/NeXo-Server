# ══════════════════════════════════════════════════════════════════════════════
#  NeXoNetwork Server — Variables de entorno
#  Copia este archivo como .env y rellena tus valores:
#    cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# "production" desactiva los logs verbose de Fastify
NODE_ENV=development

# ── Dominio base ──────────────────────────────────────────────────────────────
# El servidor detecta el módulo a usar por el header Host de cada petición.
# Pon aquí tu dominio real (sin https://, sin slash final).
# Ejemplo producción:  nexonetwork.space
# Ejemplo local:       localhost
BASE_DOMAIN=nexonetwork.space

# ── HTTPS (para Switch real con Atmosphere) ───────────────────────────────────
# La Switch verifica certificados SSL. Activa esto después de generar los certs:
#   ./scripts/gen-certs.sh
# Los certificados se guardan en /certs/ (ignorado por git).
NEXO_HTTPS=false

# ── Base de datos MySQL ───────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nexo
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=nexo_network

# Número de conexiones simultáneas al pool de MySQL.
# 10 es suficiente para desarrollo. Sube a 20-50 en producción con muchos usuarios.
DB_POOL_SIZE=10

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambia JWT_SECRET por una cadena larga y aleatoria en producción.
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=nexo_dev_secret_CHANGE_IN_PRODUCTION

# Tiempo de vida del access token (token de sesión corta)
JWT_ACCESS_EXPIRES=15m

# Tiempo de vida del refresh token (para renovar el access token sin re-login)
JWT_REFRESH_EXPIRES=30d

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Rondas de bcrypt para hashear contraseñas.
# 10 es el mínimo seguro. Más rondas = más lento pero más seguro (máx recomendado: 12).
BCRYPT_ROUNDS=10

# ── Contenido ─────────────────────────────────────────────────────────────────
# Mensaje del día — aparece en /api/v1/server/info y en el emulador al conectar.
MOTD=Bienvenido a NeXoNetwork — Open Switch Online.

# ── Sistema de actualización (panel admin) ────────────────────────────────────
# Permite actualizar el servidor desde el panel web con un botón.
# Requiere acceso al repositorio Forgejo/Gitea donde está el código.
# FORGEJO_REPO_URL=https://forgejo.joustech.space/NeXo/NeXoNetwork-Server.git
# FORGEJO_TOKEN=tu_token_de_acceso_forgejo
# ADMIN_UPDATE_SECRET=clave_secreta_para_el_webhook_de_actualizacion
