# NeXo-Server — Variables de entorno
# Copia este archivo a .env y rellena los valores

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Tu dominio base (sin www, sin https://)
# El servidor usa esto para identificar subdominios en el header Host
BASE_DOMAIN=nexonetwork.space

# Mensaje del día que aparece en el emulador
MOTD=Welcome to NeXoNetwork — Open Switch Online.

# Base de datos MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nexo_user
DB_PASSWORD=cambia_esta_contraseña
DB_NAME=nexo_network
DB_POOL_SIZE=10

# JWT — genera con: openssl rand -hex 32
JWT_SECRET=reemplaza_con_clave_larga_aleatoria_minimo_64_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

BCRYPT_ROUNDS=12

# Forgejo (para actualizaciones desde el panel admin)
FORGEJO_REPO_URL=https://forgejo.joustech.space/NeXo/NeXoNetwork-Server
FORGEJO_TOKEN=
