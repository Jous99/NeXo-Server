# =============================================
# EDEN NETWORK INFRASTRUCTURE - CONFIGURATION
# =============================================

# --- SERVER SETTINGS ---
PORT=443
NODE_ENV=development

# --- DATABASE SETTINGS (MySQL) ---
# Si usas XAMPP, el usuario por defecto es 'root' y sin contraseña
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=eden_network

# --- RAPTOR NETWORK SETTINGS ---
BASE_URL=accounts-api-lp1.raptor.network
ACCOUNT_ID=0x123456789ABCDEF