# ─────────────────────────────────────────────────────
#  NeXoNetwork Server — Variables de entorno
#  Copia este archivo como .env y rellena tus valores
# ─────────────────────────────────────────────────────

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Dominio base (para routing por subdominio)
BASE_DOMAIN=nexonetwork.space

# Base de datos MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nexo
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=nexo_network
DB_POOL_SIZE=10

# JWT
JWT_SECRET=nexo_dev_secret_CHANGE_IN_PRODUCTION
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Bcrypt (cuántas rondas para hashear contraseñas)
BCRYPT_ROUNDS=10

# Mensaje del día
MOTD=Bienvenido a NeXoNetwork — Testing local
